<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Ki2.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color (Wheeltop orange). -->
        <item name="colorPrimary">@color/hh_orange</item>
        <item name="colorPrimaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/hh_orange</item>
        <item name="colorSecondaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Dialog preference style. -->
        <item name="dialogPreferenceStyle">@style/Theme.Ki2.Preference.Dialog</item>
    </style>

    <style name="Theme.Ki2.ActionBar" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color (Wheeltop orange). -->
        <item name="colorPrimary">@color/hh_orange</item>
        <item name="colorPrimaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/hh_orange</item>
        <item name="colorSecondaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" >?attr/colorPrimaryVariant</item>

        <!-- Dialog preference style. -->
        <item name="dialogPreferenceStyle">@style/Theme.Ki2.Preference.Dialog</item>
    </style>

    <style name="Theme.Ki2.NoActionBar.Blue" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color (Wheeltop orange). -->
        <item name="colorPrimary">@color/hh_orange</item>
        <item name="colorPrimaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/hh_orange</item>
        <item name="colorSecondaryVariant">@color/hh_orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Dialog preference style. -->
        <item name="dialogPreferenceStyle">@style/Theme.Ki2.Preference.Dialog</item>
    </style>

    <style name="Theme.Ki2.Preference.Dialog" parent="Preference.Material">
        <item name="positiveButtonText">@string/text_ok</item>
        <item name="negativeButtonText">@string/text_cancel</item>
    </style>

</resources>